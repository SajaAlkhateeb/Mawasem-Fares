# Copy this file to .env.local and fill in your values.
# Vite exposes only variables prefixed with VITE_ to the browser bundle.

# Django backend base URL (include trailing slash)
VITE_API_BASE_URL=http://localhost:8000/api/v1/

# Mapbox public access token (pk.*) — used by the location picker (map +
# geocoding) and the delivery-pin thumbnails on order cards.
VITE_MAPBOX_ACCESS_TOKEN=
